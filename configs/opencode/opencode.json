{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "permission": {
    "external_directory": {
      "*": "allow",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      ".dev.vars": "deny",
      "**/.dev.vars": "deny",
      "secrets/*": "deny",
      "**/secrets/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "bash": {
      "*": "allow",
      "printenv *": "deny",
      "env": "deny",
      "env *": "deny",
      "export *": "deny",
      "gh auth *": "deny",
      "cat *.env": "deny",
      "cat *.env.*": "deny",
      "cat **/.env": "deny",
      "cat **/.env.*": "deny",
      "cat *.envrc": "deny",
      "cat **/.envrc": "deny",
      "cat .dev.vars": "deny",
      "cat **/.dev.vars": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "cat **/.aws/**": "deny",
      "cat **/.ssh/**": "deny"
    },
    "edit": "allow",
    "webfetch": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "skill": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opensrc-mcp"
      ],
      "enabled": true
    },
  }
}
