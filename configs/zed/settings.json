{
  "agent_buffer_font_size": 15.0,
  "agent_ui_font_size": 15.0,
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "light",
    "light": "Bearded Icon Theme",
    "dark": "Bearded Icon Theme",
  },
  "ui_font_family": "JetBrainsMono Nerd Font Propo",
  "buffer_font_family": "JetBrainsMono Nerd Font Propo",
  "buffer_line_height": "standard",
  "inline_code_actions": false,
